<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
      PRIVACY NOTE (v1.1):
      SoloFit is offline-first. Core nutrition logic, the food DB, and workout
      tracking all run fully on-device. A few opt-in features require limited
      connectivity / hardware:
        * INTERNET  -> Used ONLY by three opt-in features, each restricted to a
                       single allowlisted host in res/xml/network_security_config.xml
                       (cleartext disabled, every other domain blocked):
                         - Open Food Facts barcode lookups  (openfoodfacts.org)
                         - USDA FoodData Central search      (nal.usda.gov)
                         - AI food-photo estimation          (googleapis.com / Gemini)
                       NOTE: the AI food-scan feature UPLOADS the captured photo to
                       Google's Gemini API for nutrition estimation. It only runs
                       when the user explicitly taps "AI scan" and a key is set.
        * CAMERA    -> Used by the Google Code Scanner (on-device) for barcodes,
                       for progress photos (kept in app-private storage), and to
                       capture the food image sent to Gemini when AI scan is used.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Silent reminder notifications (runtime-requested on Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Reschedule reminders after a device restart. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <application
        android:name=".SoloFitApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SoloFit"
        tools:targetApi="36">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.SoloFit">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Pre-download the Google Code Scanner module from Play Services so the
          first scan doesn't stall. Optional but recommended by Google.
        -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode_ui" />

        <!-- Reschedules silent reminders after reboot. -->
        <receiver
            android:name=".reminders.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!--
          Disable WorkManager's default initializer so Hilt can provide a custom
          Configuration (with the HiltWorkerFactory) via Configuration.Provider.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
